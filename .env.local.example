# HMAC key for signing session cookies (random 32-byte hex, generate once)
SESSION_SECRET=

# Bootstrap admin (only used the first time the admin logs in; afterwards the
# admin record lives in Upstash Redis and these can be removed safely).
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Upstash Redis (via Vercel Marketplace > Storage > Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob (auto-injected when a Blob store is connected to the project)
BLOB_READ_WRITE_TOKEN=

# Telegram bot for CPA alerts (BotFather token)
TELEGRAM_BOT_TOKEN=

# Shared secret used by Vercel Cron to call /api/alerts/cron (any random string)
CRON_SECRET=

# Google AI Studio API key for the in-app AI assistant (Gemini 2.5 Pro)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
